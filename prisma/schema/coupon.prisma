model Coupon {
    id                String        @id @default(uuid(7))
    code              String        @unique
    discountType      DiscountType
    value             Float
    maxDiscountAmount Int? // Only applicable for percentage-based discounts to cap the maximum discount amount for avoiding excessive discounts.
    minOrderAmount    Int?
    usageLimit        Int?
    usedCount         Int           @default(0)
    startsAt          DateTime?
    endsAt            DateTime?
    isActive          Boolean       @default(true)
    isDeleted         Boolean       @default(false)
    createdAt         DateTime      @default(now())
    updatedAt         DateTime      @updatedAt
    deletedAt         DateTime?
    orderCoupons      OrderCoupon[]

    @@index([isDeleted])
    @@map("coupons")
}

model OrderCoupon {
    id            String   @id @default(uuid(7))
    appliedAmount Int // The actual discount amount applied to the order for this coupon. This is important to store because the discount value might change in the future, but we want to keep a record of how much discount was applied at the time of the order.
    createdAt     DateTime @default(now())

    orderId String
    order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

    couponId String
    coupon   Coupon @relation(fields: [couponId], references: [id], onDelete: Restrict)

    @@unique([orderId, couponId])
    @@index([orderId])
    @@index([couponId])
    @@map("order_coupons")
}
