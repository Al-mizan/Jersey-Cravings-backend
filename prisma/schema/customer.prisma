model Customer {
    id                     String    @id @default(uuid(7))
    name                   String
    email                  String    @unique
    profilePhoto           String?
    contactNumber          String?
    address                String?
    points                 Int       @default(0) // every time a customer buyer buy a product, they will get points, and they can use the points to redeem rewards
    lifetimePointsEarned   Int       @default(0)
    lifetimePointsRedeemed Int       @default(0)
    totalPurchasedQty      Int       @default(0)
    isDeleted              Boolean   @default(false)
    deletedAt              DateTime?
    createdAt              DateTime  @default(now())
    updatedAt              DateTime  @updatedAt

    userId              String             @unique
    user                User               @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    reviews             Review[]
    pointTransactions   PointTransaction[]
    referralCode        ReferralCode?
    referralsAsReferred ReferralEvent[]    @relation("ReferralAsReferredCustomer")

    @@index([email], name: "idx_customer_email")
    @@index([isDeleted], name: "idx_customer_isDeleted")
    @@map("customer")
}
