model PickupLocation {
    id           String               @id @default(uuid(7))
    name         String
    slug         String               @unique
    addressLine  String
    city         String
    district     String
    postalCode   String?
    phone        String
    openingHours String?
    status       PickupLocationStatus @default(ACTIVE)
    isDefault    Boolean              @default(false)
    createdAt    DateTime             @default(now())
    updatedAt    DateTime             @updatedAt

    pickupOrders Order[]

    @@index([status])
    @@map("pickup_locations")
}
