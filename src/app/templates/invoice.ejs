<!doctype html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Payment Receipt - Jersey Cravings</title>
    <style>
        :root {
            --bg: #eef2ff;
            --surface: #ffffff;
            --surface-soft: #f8fafc;
            --line: #dbe3f1;
            --text: #0f172a;
            --text-muted: #475569;
            --brand-1: #0f172a;
            --brand-2: #1d4ed8;
            --brand-3: #2563eb;
            --success-bg: #dcfce7;
            --success-text: #166534;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            padding: 18px;
            background:
                radial-gradient(circle at top right, rgba(37, 99, 235, 0.16), transparent 35%),
                radial-gradient(circle at top left, rgba(15, 23, 42, 0.1), transparent 28%),
                var(--bg);
            color: var(--text);
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        }

        .mail-shell {
            max-width: 760px;
            margin: 0 auto;
            border-radius: 18px;
            overflow: hidden;
            border: 1px solid var(--line);
            background: var(--surface);
            box-shadow: 0 14px 40px rgba(15, 23, 42, 0.12);
        }

        .hero {
            padding: 32px 32px 30px;
            background: linear-gradient(135deg, var(--brand-1) 0%, var(--brand-2) 58%, var(--brand-3) 100%);
            color: #ffffff;
            position: relative;
        }

        .hero::after {
            content: "";
            position: absolute;
            right: -70px;
            bottom: -70px;
            width: 220px;
            height: 220px;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.09);
        }

        .brand {
            margin: 0;
            font-size: 23px;
            font-weight: 800;
            letter-spacing: 0.2px;
        }

        .hero p {
            margin: 10px 0 0;
            font-size: 14px;
            line-height: 1.6;
            opacity: 0.95;
            max-width: 540px;
        }

        .content {
            padding: 30px 30px 26px;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin: 0;
            padding: 7px 14px;
            border-radius: 999px;
            background: var(--success-bg);
            color: var(--success-text);
            font-size: 12px;
            font-weight: 800;
            letter-spacing: 0.35px;
            text-transform: uppercase;
        }

        .heading {
            margin: 16px 0 8px;
            font-size: 26px;
            line-height: 1.22;
        }

        .lede {
            margin: 0;
            color: var(--text-muted);
            font-size: 14px;
            line-height: 1.72;
        }

        .meta-grid {
            margin-top: 24px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        .meta-card {
            border: 1px solid var(--line);
            border-radius: 12px;
            background: var(--surface-soft);
            padding: 14px 15px;
        }

        .meta-label {
            margin: 0;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            color: #64748b;
        }

        .meta-value {
            margin: 6px 0 0;
            font-size: 14px;
            line-height: 1.45;
            color: var(--text);
            font-weight: 700;
            word-break: break-word;
        }

        .section-title {
            margin: 30px 0 12px;
            font-size: 16px;
            line-height: 1.3;
        }

        .table-wrap {
            border: 1px solid var(--line);
            border-radius: 12px;
            overflow: hidden;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background: var(--surface);
        }

        th,
        td {
            padding: 11px 12px;
            font-size: 13px;
            border-bottom: 1px solid var(--line);
            text-align: left;
            vertical-align: top;
        }

        thead th {
            background: #eff6ff;
            color: #1e3a8a;
            font-weight: 800;
        }

        tbody tr:nth-child(even) {
            background: #f8fafc;
        }

        tbody tr:last-child td {
            border-bottom: none;
        }

        .amount {
            text-align: right;
            white-space: nowrap;
        }

        .summary {
            margin-top: 16px;
            margin-left: auto;
            width: min(360px, 100%);
            border: 1px solid var(--line);
            border-radius: 12px;
            padding: 14px;
            background: var(--surface-soft);
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 20px;
            margin-bottom: 8px;
            color: #334155;
            font-size: 13px;
        }

        .summary-row:last-child {
            margin-bottom: 0;
        }

        .summary-row.total {
            margin-top: 10px;
            padding-top: 10px;
            border-top: 1px solid #cbd5e1;
            color: #0f172a;
            font-size: 16px;
            font-weight: 800;
        }

        .cta {
            margin-top: 20px;
            text-align: center;
        }

        .cta a {
            display: inline-block;
            text-decoration: none;
            background: linear-gradient(135deg, var(--brand-2), var(--brand-3));
            color: #ffffff;
            padding: 12px 20px;
            border-radius: 10px;
            font-weight: 700;
            font-size: 13px;
        }

        .help {
            margin-top: 20px;
            color: #64748b;
            font-size: 12px;
            line-height: 1.75;
        }

        .help a,
        .footer a {
            color: var(--brand-2);
            text-decoration: none;
            font-weight: 600;
        }

        .footer {
            padding: 16px 24px 20px;
            text-align: center;
            border-top: 1px solid var(--line);
            background: #f8fafc;
            color: #64748b;
            font-size: 12px;
            line-height: 1.7;
        }

        @media (max-width: 640px) {
            body {
                padding: 10px;
            }

            .hero,
            .content {
                padding-left: 18px;
                padding-right: 18px;
            }

            .heading {
                font-size: 22px;
            }

            .meta-grid {
                grid-template-columns: 1fr;
            }

            th,
            td {
                font-size: 12px;
                padding: 10px;
            }

            .summary {
                width: 100%;
            }
        }
    </style>
</head>

<body>
    <%
        const formatMoney = (value) => `${Number(value || 0).toFixed(2)} BDT`;
        const safeItems = Array.isArray(items) ? items : [];
        const hasDiscount = Number(discount || 0) > 0;
        const hasShipping = Number(shipping || 0) > 0;
        const hasGiftAddon = Number(giftAddon || 0) > 0;
    %>

    <div class="mail-shell">
        <div class="hero">
            <h1 class="brand">Jersey Cravings</h1>
            <p>
                Payment received for your order.
                We attached your receipt PDF to this email and saved a cloud copy for future access.
            </p>
        </div>

        <div class="content">
            <p class="badge">Payment Confirmed</p>
            <h2 class="heading">Thanks, <%= customerName %>!</h2>
            <p class="lede">
                Your payment for order <strong><%= orderNumber %></strong> has been completed successfully.
                Please keep this email as your official payment receipt.
            </p>

            <div class="meta-grid">
                <div class="meta-card">
                    <p class="meta-label">Invoice ID</p>
                    <p class="meta-value"><%= invoiceId %></p>
                </div>
                <div class="meta-card">
                    <p class="meta-label">Transaction ID</p>
                    <p class="meta-value"><%= transactionId %></p>
                </div>
                <div class="meta-card">
                    <p class="meta-label">Order Date</p>
                    <p class="meta-value"><%= orderDate %></p>
                </div>
                <div class="meta-card">
                    <p class="meta-label">Payment Date</p>
                    <p class="meta-value"><%= paymentDate %></p>
                </div>
            </div>

            <h3 class="section-title">Order Items</h3>
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th class="amount">Qty</th>
                            <th class="amount">Unit Price</th>
                            <th class="amount">Line Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (safeItems.length> 0) { %>
                            <% safeItems.forEach((item)=> { %>
                                <tr>
                                    <td><%= item.productTitle %></td>
                                    <td class="amount"><%= item.qty %></td>
                                    <td class="amount"><%= formatMoney(item.unitPrice) %></td>
                                    <td class="amount"><%= formatMoney(item.lineTotal) %></td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="4">No line items available</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <div class="summary">
                <div class="summary-row">
                    <span>Subtotal</span>
                    <strong><%= formatMoney(subtotal) %></strong>
                </div>

                <% if (hasDiscount) { %>
                    <div class="summary-row">
                        <span>Discount</span>
                        <strong>- <%= formatMoney(discount) %></strong>
                    </div>
                <% } %>

                <% if (hasShipping) { %>
                    <div class="summary-row">
                        <span>Shipping</span>
                        <strong>+ <%= formatMoney(shipping) %></strong>
                    </div>
                <% } %>

                <% if (hasGiftAddon) { %>
                    <div class="summary-row">
                        <span>Gift Add-on</span>
                        <strong>+ <%= formatMoney(giftAddon) %></strong>
                    </div>
                <% } %>

                <div class="summary-row total">
                    <span>Total Paid</span>
                    <span><%= formatMoney(totalAmount) %></span>
                </div>
            </div>

            <% if (invoiceUrl) { %>
                <div class="cta">
                    <a href="<%= invoiceUrl %>" target="_blank" rel="noopener noreferrer">
                        Download Receipt PDF
                    </a>
                </div>
            <% } %>

            <p class="help">
                Need help with this payment?
                Contact <a href="mailto:support@jerseycravings.com">support@jerseycravings.com</a>
                and include your order number.
            </p>
        </div>

        <div class="footer">
            <div><strong>Jersey Cravings</strong></div>
            <div>&copy; 2026 Jersey Cravings. All rights reserved.</div>
            <div>
                <a href="https://jerseycravings.com">Website</a>
                &nbsp;|&nbsp;
                <a href="mailto:support@jerseycravings.com">Support</a>
            </div>
        </div>
    </div>
</body>

</html>
